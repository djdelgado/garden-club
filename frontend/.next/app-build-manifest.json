      "static/chunks/main-app.js",
      "static/chunks/app/(app)/gallery/page.js"
    ],
    "/(auth)/signin/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(auth)/signin/page.css",
      "static/chunks/app/(auth)/signin/page.js"
    ],
    "/(app)/home/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
